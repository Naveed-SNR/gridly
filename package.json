{
  "name": "gridly",
  "displayName": "Gridly",
  "version": "0.0.1",
  "description": "A lightweight design tool for overlaying customizable grids onto any website",
  "author": "Naveed SNR ",
  "scripts": {
    "dev": "plasmo dev",
    "build": "npm run build:chrome && npm run build:firefox",
    "build:chrome": "plasmo build --target=chrome-mv3",
    "build:firefox": "plasmo build --target=firefox-mv2",
    "package": "plasmo package"
  },
  "dependencies": {
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "prettier": "3.2.4",
    "tailwindcss": "^3.4.19",
    "typescript": "5.3.3"
  },
  "manifest": {
    "host_permissions": [
      "<all_urls>"
    ],
    "permissions": [
      "storage"
    ],
    "incognito": "spanning"
  }
  }
